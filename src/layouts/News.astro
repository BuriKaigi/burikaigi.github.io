---
import Layout from '~/layouts/Vanilla.astro';
import type { NewsFrontmatter } from '~/types/news';

interface Props {
  frontmatter: NewsFrontmatter;
}

const { frontmatter } = Astro.props;

const shareUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.toString();
const shareIntent = `https://twitter.com/intent/tweet?text=${encodeURIComponent(
  frontmatter.title
)}&url=${encodeURIComponent(shareUrl)}&hashtags=burikaigi`;
---

<Layout
  name={frontmatter.title}
  ogTitle={frontmatter.title}
  ogType="article"
  ogDescription={frontmatter.summary}
  publishedTime={`${frontmatter.date}T00:00:00+09:00`}
>
  <div class="font-biz-udp min-h-screen bg-gradient-to-br from-slate-950 via-slate-900 to-blue-950 text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-950/80 via-slate-900/70 to-blue-950/80 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-cyan-300/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-blue-200/10 rounded-full blur-3xl pointer-events-none"></div>

    <header class="relative z-10 sticky top-0 bg-slate-950/60 backdrop-blur-md border-b border-white/10">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a
          href="/"
          class="text-lg font-semibold bg-gradient-to-r from-blue-400 via-cyan-300 to-white bg-clip-text text-transparent hover:opacity-80 transition-opacity rounded focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300"
        >
          BuriKaigi
        </a>
        <a
          href="/news/"
          class="text-sm text-white/70 hover:text-white/90 transition-colors rounded focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300"
        >
          お知らせ一覧
        </a>
      </div>
    </header>

    <main class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <article class="bg-white/5 backdrop-blur-md rounded-2xl p-6 sm:p-10 border border-white/10 shadow-2xl">
        <p class="text-xs sm:text-sm text-white/60 font-light tracking-widest uppercase mb-3">
          News
        </p>
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-semibold leading-snug mb-4 bg-gradient-to-r from-blue-400 via-cyan-300 to-white bg-clip-text text-transparent">
          {frontmatter.title}
        </h1>
        <time
          datetime={frontmatter.date}
          class="block text-sm text-white/70 font-light tracking-wider mb-8"
        >
          {frontmatter.date}
        </time>

        <div class="news-body text-white/85 leading-relaxed">
          <slot />
        </div>

        <div class="mt-10 pt-6 border-t border-white/10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <span class="text-xs text-white/60 font-light tracking-widest uppercase">
            Share
          </span>
          <a
            href={shareIntent}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-white/5 hover:bg-white/10 backdrop-blur-md rounded-full border border-white/10 hover:border-white/30 text-white/85 hover:text-white transition-all duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-300"
            aria-label="この記事を X でシェア"
          >
            <img
              src="/images/x.svg"
              alt=""
              width="16"
              height="16"
              class="h-4 w-4 invert opacity-90 group-hover:opacity-100 transition-opacity"
              aria-hidden="true"
            />
            <span class="text-sm">この記事をシェア</span>
          </a>
        </div>
      </article>

      <div class="mt-10 text-center">
        <a
          href="/news/"
          class="inline-flex items-center gap-2 px-6 sm:px-8 py-3 sm:py-4 bg-white/5 hover:bg-white/10 backdrop-blur-md rounded-full border border-white/10 hover:border-white/30 text-white/85 hover:text-white transition-all duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-300"
        >
          ← お知らせ一覧に戻る
        </a>
      </div>
    </main>
  </div>
</Layout>

<style is:global>
  .news-body h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: rgba(255, 255, 255, 0.95);
  }
  .news-body h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    color: rgba(255, 255, 255, 0.95);
  }
  .news-body p {
    margin-top: 1rem;
    line-height: 1.9;
  }
  .news-body strong {
    color: rgba(255, 255, 255, 0.95);
    font-weight: 700;
  }
  .news-body a {
    color: #67e8f9;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(103, 232, 249, 0.4);
    transition: color 0.2s, text-decoration-color 0.2s;
  }
  .news-body a:hover {
    color: #a5f3fc;
    text-decoration-color: rgba(165, 243, 252, 0.8);
  }
  .news-body ul,
  .news-body ol {
    margin-top: 1rem;
    padding-left: 1.5rem;
    list-style-position: outside;
  }
  .news-body ul {
    list-style-type: disc;
  }
  .news-body ol {
    list-style-type: decimal;
  }
  .news-body li {
    margin-top: 0.4rem;
    line-height: 1.85;
  }
  .news-body li::marker {
    color: rgba(165, 243, 252, 0.6);
  }
  .news-body code {
    background-color: rgba(255, 255, 255, 0.08);
    color: #a5f3fc;
    padding: 0.15em 0.45em;
    border-radius: 0.3rem;
    font-size: 0.9em;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .news-body pre {
    background-color: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #e2e8f0;
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-top: 1.25rem;
  }
  .news-body pre code {
    background: transparent;
    border: none;
    padding: 0;
    color: inherit;
  }
  .news-body blockquote {
    border-left: 3px solid #67e8f9;
    padding-left: 1rem;
    color: rgba(255, 255, 255, 0.65);
    margin-top: 1rem;
    font-style: italic;
  }
  .news-body hr {
    border: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.2), transparent);
    margin: 2.5rem 0;
  }
</style>

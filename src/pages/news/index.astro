---
import Layout from '~/layouts/Vanilla.astro';
import type { NewsItem, NewsModule } from '~/types/news';
import { resolveLink } from '~/types/news';

const allNews = Object.values(
  import.meta.glob<NewsModule>('./*.md', { eager: true })
);

const news: NewsItem[] = allNews
  .map((m) => ({
    ...m.frontmatter,
    url: m.url.endsWith('/') ? m.url : `${m.url}/`,
  }))
  .sort((a, b) => (a.date < b.date ? 1 : -1));
---

<Layout title="お知らせ" ogTitle="お知らせ | BuriKaigi">
  <div class="font-biz-udp min-h-screen bg-gradient-to-br from-slate-950 via-slate-900 to-blue-950 text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-950/80 via-slate-900/70 to-blue-950/80 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-cyan-300/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-blue-200/10 rounded-full blur-3xl pointer-events-none"></div>

    <header class="relative z-10 sticky top-0 bg-slate-950/60 backdrop-blur-md border-b border-white/10">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a
          href="/"
          class="text-lg font-semibold bg-gradient-to-r from-blue-400 via-cyan-300 to-white bg-clip-text text-transparent hover:opacity-80 transition-opacity rounded focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300"
        >
          BuriKaigi
        </a>
        <span class="text-sm text-white/60 font-light tracking-widest uppercase">News</span>
      </div>
    </header>

    <main class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-20">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-xs sm:text-sm text-white/60 font-light tracking-widest uppercase mb-3">
          News
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-wide bg-gradient-to-r from-blue-400 via-cyan-300 to-white bg-clip-text text-transparent">
          お知らせ
        </h1>
      </div>

      {news.length === 0 ? (
        <p class="text-center text-white/70">お知らせはまだありません。</p>
      ) : (
        <ul class="space-y-3 sm:space-y-4">
          {news.map((item) => {
            const { href, isExternal } = resolveLink(item);
            return (
              <li>
                <a
                  href={href}
                  target={isExternal ? '_blank' : undefined}
                  rel={isExternal ? 'noopener noreferrer' : undefined}
                  class="group block bg-white/5 hover:bg-white/10 backdrop-blur-md rounded-xl px-5 sm:px-6 py-4 sm:py-5 border border-white/10 hover:border-white/30 transition-all duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-300"
                >
                  <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-5">
                    <time
                      datetime={item.date}
                      class="text-xs sm:text-sm text-white/70 font-light tracking-wider whitespace-nowrap"
                    >
                      {item.date}
                    </time>
                    <h2 class="text-base sm:text-lg text-white/90 group-hover:text-white font-light leading-snug transition-colors">
                      {item.title}
                      {isExternal && (
                        <>
                          <span aria-hidden="true" class="ml-2 text-xs text-white/60">↗</span>
                          <span class="sr-only">（外部リンク）</span>
                        </>
                      )}
                    </h2>
                  </div>
                  {item.summary && (
                    <p class="mt-2 sm:mt-2.5 sm:pl-[7.5rem] text-sm text-white/70 leading-relaxed">
                      {item.summary}
                    </p>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      )}

      <div class="mt-14 text-center">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 sm:px-8 py-3 sm:py-4 bg-white/5 hover:bg-white/10 backdrop-blur-md rounded-full border border-white/10 hover:border-white/30 text-white/85 hover:text-white transition-all duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-300"
        >
          ← トップに戻る
        </a>
      </div>
    </main>
  </div>
</Layout>

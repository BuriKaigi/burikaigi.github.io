  a.date.localeCompare(b.date)
);
const sortedReportPosts = [...reportPosts].sort((a, b) => a.date.localeCompare(b.date));
---

<Layout title="参加レポート">
  <div class="bg-gradient-to-br from-slate-50 via-blue-50 to-cyan-50 text-gray-900 scroll-smooth">
    <header class="sticky top-0 z-40 bg-white/90 backdrop-blur border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <img src="/images/burikaigi-logo.png" alt="BuriKaigi ロゴ" class="w-10 h-10 object-contain" />
          <span class="font-semibold text-lg">BuriKaigi 2026</span>
        </div>
        <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
          <a href="/#about" class="hover:text-teal-600 transition-colors">概要</a>
          <a href="/#keynote" class="hover:text-teal-600 transition-colors">基調講演</a>
          <a href="/#workshops" class="hover:text-teal-600 transition-colors">ワークショップ</a>
          <a href="/#sponsors" class="hover:text-teal-600 transition-colors">スポンサー</a>
          <a href="/#event-info" class="hover:text-teal-600 transition-colors">開催情報</a>
          <a href="/report" class="text-teal-700">参加レポート</a>
          <a href="/coc" class="hover:text-teal-600 transition-colors">CoC</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="relative overflow-hidden pt-20 pb-10">
        <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-5">
          <p class="inline-flex items-center gap-2 bg-teal-600 text-white px-5 py-2 rounded-full text-sm shadow">イベント終了</p>
          <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight">BuriKaigi 2026 参加レポート</h1>
          <p class="text-lg text-gray-700 max-w-3xl mx-auto leading-relaxed">
            ご参加・ご登壇・ご協賛いただきありがとうございます。<br />イベント当日の雰囲気を簡潔にまとめました。
          </p>
          <div class="mx-auto max-w-2xl rounded-2xl border border-teal-200 bg-teal-50 px-5 py-4 text-base text-teal-900 shadow-sm">
            <p class="font-semibold">内容は順次追記していきます。</p>
          </div>
        </div>
      </section>

      <section id="management-reports" class="pb-12">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-8">
            <h2 class="text-2xl sm:text-3xl font-semibold">運営レポート</h2>
            <p class="text-gray-700 mt-2">運営チームからのレポートをご紹介します。</p>
          </div>
          {sortedManagementReportPosts.length === 0 ? (
            <div class="mx-auto max-w-2xl rounded-2xl border border-gray-200 bg-white px-6 py-6 text-center text-gray-600 shadow-sm">
              近日公開予定です。
            </div>
          ) : (
            <div class="grid gap-6 sm:grid-cols-2">
              {sortedManagementReportPosts.map((post) => (
                <a
                  href={post.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group bg-white rounded-3xl overflow-hidden shadow-lg border border-gray-200 hover:border-teal-500 hover:shadow-xl transition-colors"
                >
                  <div class="aspect-[16/9] bg-gray-100 overflow-hidden">
                    <img
                      src={post.image}
                      alt={post.title}
                      class="h-full w-full object-cover group-hover:scale-105 transition-transform"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-6">
                    <div class="flex items-center justify-between text-xs text-gray-500">
                      <span>{post.date}</span>
                      <span>@{post.account}</span>
                    </div>
                    <h3 class="text-lg font-semibold text-gray-900 mt-2">{post.title}</h3>
                    <span class="inline-flex items-center gap-2 text-sm text-teal-700 mt-4">
                      ブログを読む
                    </span>
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      </section>

      <section id="reports" class="pb-12">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-8">
            <h2 class="text-2xl sm:text-3xl font-semibold">参加レポート</h2>
            <p class="text-gray-700 mt-2">参加いただいた皆さんのレポートをご紹介します。</p>
          </div>
          <div class="grid grid-cols-2 gap-6 lg:grid-cols-3">
            {sortedReportPosts.map((post) => (
              <a
                href={post.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group bg-white rounded-3xl overflow-hidden shadow-lg border border-gray-200 hover:border-teal-500 hover:shadow-xl transition-colors"
              >
                <div class="aspect-[16/9] bg-gray-100 overflow-hidden">
                  <img
                    src={post.image}
                    alt={post.title}
                    class="h-full w-full object-cover group-hover:scale-105 transition-transform"
                    loading="lazy"
                  />
                </div>
                <div class="p-6">
                  <div class="flex items-center justify-between text-xs text-gray-500">
                    <span>{post.date}</span>
                    <span>@{post.account}</span>
                  </div>
                  <h3 class="text-lg font-semibold text-gray-900 mt-2">{post.title}</h3>
                  <span class="inline-flex items-center gap-2 text-sm text-teal-700 mt-4">
                    ブログを読む
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section id="next" class="pb-16">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="bg-teal-600 rounded-3xl p-8 shadow-xl border border-teal-600 text-white">
            <h2 class="text-2xl font-semibold mb-4">次回に向けて</h2>
            <p class="text-teal-50 leading-relaxed">
              BuriKaigiは皆さまのフィードバックでより良いイベントへ成長していきます。感想やご意見がありましたら、公式Xやコミュニティ経由でお寄せください。
            </p>
            <div class="mt-6">
              <a href="/" class="inline-flex items-center gap-2 bg-white text-teal-700 px-6 py-3 rounded-full shadow">
                トップページへ戻る
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</Layout>
